---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categories, logoOptions } from "../../data/products";
import { site } from "../../data/site";

export function getStaticPaths() {
  return categories.map((category) => ({ params: { slug: category.slug }, props: { category } }));
}

const { category } = Astro.props;
const title = `${category.title} Wholesale | Custom Bags with Logo Manufacturer`;
const description = `${category.description} MOQ ${site.moq}. Custom logo, size, material and packing support for B2B buyers.`;
const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: category.title,
  image: category.image,
  description,
  brand: { "@type": "Brand", name: "JasunBag" },
  offers: { "@type": "Offer", availability: "https://schema.org/InStock", priceCurrency: "USD", price: "0" },
};
---
<BaseLayout title={title} description={description} schema={schema}>
  <section class="page-hero">
    <p class="eyebrow">Wholesale category</p>
    <h1>{category.title}</h1>
    <p>{category.description}</p>
  </section>
  <section class="section split">
    <img src={category.image} alt={`${category.title} custom logo packaging bag manufacturer`} />
    <div>
      <p class="eyebrow">B2B sourcing details</p>
      <h2>Customizable for brand packaging programs.</h2>
      <p>MOQ: {site.moq}. Send your size, target material, logo artwork, color, quantity and destination market for quotation.</p>
      <div class="tag-row">{category.keywords.map((kw) => <span>{kw}</span>)}</div>
      <div class="actions"><a class="btn" href="/contact/">Request Wholesale Price</a></div>
    </div>
  </section>
  <section class="section band">
    <p class="eyebrow">Options</p>
    <h2>Logo and production options</h2>
    <div class="option-grid">
      {logoOptions.slice(0, 6).map((option) => <div class="tile"><h3>{option}</h3><p>Confirm availability based on selected fabric, quantity and logo artwork.</p></div>)}
    </div>
  </section>
  <section class="section">
    <p class="eyebrow">Applications</p>
    <h2>Common use cases</h2>
    <div class="grid-4">
      {category.applications.map((app) => <div class="tile"><h3>{app}</h3><p>Suitable for repeatable packaging programs and seasonal custom orders.</p></div>)}
    </div>
  </section>
  <section class="section band">
    <p class="eyebrow">FAQ</p>
    <h2>Buyer questions</h2>
    <div class="grid-3">
      <div class="tile"><h3>What is the MOQ?</h3><p>Most custom styles start from {site.moq}, depending on material, size and logo process.</p></div>
      <div class="tile"><h3>Can you make samples?</h3><p>Yes. Samples can be arranged after material, size and artwork are confirmed.</p></div>
      <div class="tile"><h3>Can I customize the logo?</h3><p>Yes. Common methods include printing, embroidery, foil stamping, embossing and woven labels.</p></div>
    </div>
  </section>
</BaseLayout>
